---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Posts — ${SITE_TITLE}`}
			description={`Notes from an operator learning to build. ${SITE_DESCRIPTION}`}
		/>
	</head>
	<body>
		<Header />

		<main class="wrap">
			<div class="archive-header">
				<div class="hero-eyebrow">All posts — newest first</div>
				<h1 class="archive-title">Posts</h1>
				<p class="archive-sub">
					What I'm learning along the way. One per month, roughly.
				</p>
			</div>

			<ul class="post-list">
				{
					posts.map((post) => (
						<li class="post-item">
							<a href={`/blog/${post.id}/`} class="post-link">
								<div class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</div>
								<div class="post-content">
									<div class="post-title">{post.data.title}</div>
									<div class="post-teaser">{post.data.description}</div>
								</div>
							</a>
						</li>
					))
				}
			</ul>
		</main>

		<Footer />
	</body>
</html>

<style>
	.archive-header {
		padding: 96px 0 56px;
		border-bottom: 1px solid var(--rule);
	}
	.hero-eyebrow {
		font-family: var(--font-mono), monospace;
		font-size: 12px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--ink-faint);
		margin-bottom: 24px;
		display: flex;
		align-items: center;
		gap: 12px;
	}
	.hero-eyebrow::before {
		content: '';
		width: 24px;
		height: 1px;
		background: var(--accent);
	}
	.archive-title {
		font-family: var(--font-serif), Georgia, serif;
		font-weight: 500;
		font-size: clamp(38px, 5.5vw, 56px);
		letter-spacing: -0.02em;
		line-height: 1.08;
		margin-bottom: 20px;
		color: var(--ink);
	}
	.archive-sub {
		font-family: var(--font-serif), Georgia, serif;
		font-size: 19px;
		color: var(--ink-soft);
		font-style: italic;
	}

	.post-list {
		list-style: none;
		padding: 64px 0;
		margin: 0;
	}
	.post-item {
		border-top: 1px solid var(--rule-soft);
	}
	.post-item:first-child {
		border-top: none;
	}
	.post-link {
		display: grid;
		grid-template-columns: 80px 1fr;
		gap: 24px;
		align-items: baseline;
		padding: 28px 16px;
		margin: 0 -16px;
		border-radius: 2px;
		transition: background 0.2s;
		text-decoration: none;
		color: inherit;
	}
	.post-link:hover {
		background: var(--bg-elev);
		opacity: 1;
	}
	.post-link:hover .post-title {
		color: var(--accent);
	}
	.post-date {
		font-family: var(--font-mono), monospace;
		font-size: 11px;
		color: var(--ink-faint);
		letter-spacing: 0.05em;
		padding-top: 6px;
		text-transform: uppercase;
	}
	.post-content {
		display: flex;
		flex-direction: column;
		gap: 6px;
	}
	.post-title {
		font-family: var(--font-serif), Georgia, serif;
		font-size: 22px;
		line-height: 1.25;
		font-weight: 500;
		color: var(--ink);
		letter-spacing: -0.01em;
		transition: color 0.2s;
	}
	.post-teaser {
		font-family: var(--font-sans), sans-serif;
		font-size: 15px;
		color: var(--ink-soft);
		line-height: 1.5;
	}
	@media (max-width: 640px) {
		.archive-header {
			padding: 64px 0 48px;
		}
		.archive-title {
			font-size: 36px;
		}
		.post-link {
			grid-template-columns: 1fr;
			gap: 6px;
			padding: 20px 16px;
		}
	}
</style>
